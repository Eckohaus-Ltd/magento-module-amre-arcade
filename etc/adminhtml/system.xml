<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="eckohaus_os" translate="label" sortOrder="10">
            <label>Eckohaus OS</label>
        </tab>
        
        <section id="amre_arcade" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
            <class>separator-top</class>
            <label>AMRE Arcade (Jupiter-IV)</label>
            <tab>eckohaus_os</tab>
            <resource>Eckohaus_AmreArcade::config</resource>
            
            <group id="general" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Connection Settings</label>
                
                <field id="fortran_endpoint" translate="label comment" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Fortran API Endpoint</label>
                    <comment><![CDATA[Internal server route to the Nginx block. Default: http://127.0.0.1:8080/calculate]]></comment>
                </field>
                
            </group>
        </section>
    </system>
</config>
