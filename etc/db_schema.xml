<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="eckohaus_amre_wallet" resource="default" engine="innodb" comment="AMRE Arcade Token Wallet">
        
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        
        <column xsi:type="int" name="customer_id" unsigned="true" nullable="false" comment="Customer ID"/>
        
        <column xsi:type="int" name="token_balance" unsigned="false" nullable="false" default="0" comment="Token Balance"/>
        
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        
        <constraint xsi:type="foreign" referenceId="FK_ECKOHAUS_AMRE_WALLET_CUSTOMER_ID" table="eckohaus_amre_wallet" column="customer_id" referenceTable="customer_entity" referenceColumn="entity_id" onDelete="CASCADE"/>
        
    </table>
</schema>
